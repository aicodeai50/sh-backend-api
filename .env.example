# ===============================
# Docker (project name: zentro-backend / Zentro Backend)
# ===============================
# COMPOSE_PROJECT_NAME=zentro-backend
# docker compose -p zentro-backend up -d --build

# ===============================
# Core server
# ===============================
PORT=8080
NODE_ENV=development
SH_API_KEY=your-api-key
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d

# Comma-separated origins, or set CORS_ALLOW_ALL=true for any frontend
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:5173
# CORS_ALLOW_ALL=true

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ===============================
# SQL database (Sequelize ORM)
# Supported: sqlite, postgres, mysql, mariadb, mssql
# ===============================

# Option A: SQLite (default, zero setup)
DB_DIALECT=sqlite
DB_STORAGE=./database.sqlite

# Option B: PostgreSQL (recommended for Railway production)
# DB_DIALECT=postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/shynvo
# On Railway (sh-backend-prod), reference linked services:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# DB_DIALECT=postgres

# Option C: MySQL / MariaDB
# DB_DIALECT=mysql
# DATABASE_URL=mysql://user:password@localhost:3306/shynvo

# Option D: SQL Server
# DB_DIALECT=mssql
# DATABASE_URL=mssql://user:password@localhost:1433/shynvo
# DB_ENCRYPT=true
# DB_TRUST_SERVER_CERT=false

# Or use individual fields instead of DATABASE_URL:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=shynvo
# DB_USER=postgres
# DB_PASSWORD=secret

# DB_LOGGING=false
# FORCE_DB_SYNC=0

# ===============================
# OmsorgPilot / zentro.pri integration
# ===============================
ZENTRO_PRI_URL=https://pri.zentro.run
# ZENTRO_PRI_CHAT_URL=https://pri.zentro.run/api/public/chat
# ZENTRO_PRI_TWIN_URL=
# OMSORGPILOT_AI_CHAT_URL=https://robot.zentro.run/api/public/chat

# Tables exposed via GET/POST /api/v1/sql/:table (comma-separated model names)
GENERIC_SQL_TABLES=GenericRecord

# ===============================
# OmsorgPilot / zentro.pri integration
# ===============================
ZENTRO_PRI_URL=https://pri.zentro.run
# ZENTRO_PRI_CHAT_URL=https://robot.zentro.run/api/public/chat
# ZENTRO_PRI_TWIN_URL=
# OMSORGPILOT_AI_CHAT_URL=https://robot.zentro.run/api/public/chat

# Varsling ved ny produkt-tilbakemelding (velg én eller flere):
# FEEDBACK_NOTIFY_WEBHOOK_URL=https://hooks.example.com/omsorg-feedback
# FEEDBACK_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# FEEDBACK_TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
# FEEDBACK_NOTIFY_EMAIL=superbruker@baerum.kommune.no
# RESEND_API_KEY=
# FEEDBACK_NOTIFY_FROM=OmsorgPilot <noreply@dittdomene.no>

# Ukesrapport-varsling ved auto-generert utkast (mandag kl. 06:00):
# WEEKLY_REPORT_NOTIFY_EMAIL=leder@baerum.kommune.no
# WEEKLY_REPORT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# WEEKLY_REPORT_NOTIFY_FROM=OmsorgPilot <noreply@dittdomene.no>

# Varsling ved kritisk/høyt avvik (e-post/Slack/Teams):
# DEVIATION_CRITICAL_NOTIFY_EMAIL=leder@baerum.kommune.no
# DEVIATION_CRITICAL_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# DEVIATION_CRITICAL_TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
# DEVIATION_CRITICAL_NOTIFY_FROM=OmsorgPilot <noreply@dittdomene.no>
# DEVIATION_CRITICAL_SMS_TO=+4799999999

# Twilio SMS (valgfritt — brukes ved kritisk avvik når DEVIATION_CRITICAL_SMS_TO er satt):
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+4712345678

# Web Push (VAPID) — generer med: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:leder@baerum.kommune.no

# ===============================
# MongoDB (optional document store)
# When off, documents use SQL GenericRecord table automatically
# ===============================
# MONGODB_ENABLED=true
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DB=shynvo
# Railway: MONGODB_URI=${{MongoDB.MONGO_URL}}  MONGODB_ENABLED=true

# ===============================
# Redis (optional cache)
# When off, in-memory cache is used automatically
# ===============================
# REDIS_ENABLED=true
# REDIS_URL=redis://localhost:6379
# REDIS_KEY_PREFIX=sh:
# REDIS_DEFAULT_TTL_SECONDS=3600
# Railway: REDIS_URL=${{Redis.REDIS_URL}}  REDIS_ENABLED=true

# ===============================
# S3 / Cloudflare R2 (optional file storage)
# When off, files use UPLOADS_DIR (local volume in Docker/Railway)
# ===============================
# S3_ENABLED=true
# S3_BUCKET=your-bucket
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_PUBLIC_URL=https://cdn.example.com
# S3_KEY_PREFIX=uploads/
# S3_FORCE_PATH_STYLE=true

# ===============================
# Universal storage
# ===============================
STORAGE_MEMORY_FALLBACK=true
UPLOADS_DIR=./uploads
# Railway: mount volume at /app/uploads and set UPLOADS_DIR=/app/uploads
MAX_UPLOAD_BYTES=10485760
