# ===============================
# Docker (project name: zentro-backend / Zentro Backend)
# ===============================
# COMPOSE_PROJECT_NAME=zentro-backend
# docker compose -p zentro-backend up -d --build

# ===============================
# Core server
# ===============================
PORT=8080
NODE_ENV=development
SH_API_KEY=your-api-key
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d

# Comma-separated origins, or set CORS_ALLOW_ALL=true for any frontend
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:5173
# CORS_ALLOW_ALL=true

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ===============================
# SQL database (Sequelize ORM)
# Supported: sqlite, postgres, mysql, mariadb, mssql
# ===============================

# Option A: SQLite (default, zero setup)
DB_DIALECT=sqlite
DB_STORAGE=./database.sqlite

# Option B: PostgreSQL
# DB_DIALECT=postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/shynvo

# Option C: MySQL / MariaDB
# DB_DIALECT=mysql
# DATABASE_URL=mysql://user:password@localhost:3306/shynvo

# Option D: SQL Server
# DB_DIALECT=mssql
# DATABASE_URL=mssql://user:password@localhost:1433/shynvo
# DB_ENCRYPT=true
# DB_TRUST_SERVER_CERT=false

# Or use individual fields instead of DATABASE_URL:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=shynvo
# DB_USER=postgres
# DB_PASSWORD=secret

# DB_LOGGING=false
# FORCE_DB_SYNC=0

# Tables exposed via GET/POST /api/v1/sql/:table (comma-separated model names)
GENERIC_SQL_TABLES=GenericRecord

# ===============================
# MongoDB (optional document store)
# When off, documents use SQL GenericRecord table automatically
# ===============================
# MONGODB_ENABLED=true
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DB=shynvo

# ===============================
# Redis (optional cache)
# When off, in-memory cache is used automatically
# ===============================
# REDIS_ENABLED=true
# REDIS_URL=redis://localhost:6379
# REDIS_KEY_PREFIX=sh:
# REDIS_DEFAULT_TTL_SECONDS=3600

# ===============================
# Universal storage
# ===============================
STORAGE_MEMORY_FALLBACK=true
UPLOADS_DIR=./uploads
MAX_UPLOAD_BYTES=10485760
