{
  "name": "sh-backend-api",
  "version": "1.0.0",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "docker:up": "docker compose -p zentro-backend up -d --build",
    "docker:down": "docker compose -p zentro-backend down",
    "docker:logs": "docker compose -p zentro-backend logs -f backend",
    "verify:railway": "node scripts/verify-railway.js",
    "verify:company": "node scripts/verify-company.js",
    "verify:all": "node scripts/verify-all.js",
    "railway:sync-env": "node scripts/sync-railway-env.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.16.0",
    "mysql2": "^3.14.1",
    "openai": "^4.104.0",
    "pg": "^8.16.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "tedious": "^18.6.1",
    "web-push": "^3.6.7"
  }
}
